# Database Configuration - Individual Components (Recommended)
# These will be automatically combined into a connection URL
DB_DRIVER=postgresql+asyncpg
DB_USER=tppuser
DB_PASSWORD=tppdev123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=themeparkplanner

# Alternative: Override with complete DATABASE_URL if needed
# DATABASE_URL=postgresql+asyncpg://username:password@db-host:5432/database_name

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-change-in-production

# Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Theme Park Planner API

# Database Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Connection Settings
REDIS_MAX_CONNECTIONS=10

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
