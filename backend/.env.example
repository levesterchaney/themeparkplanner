# Database Configuration
# For development (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://tppuser:tppdev123@localhost:5432/themeparkplanner

# For production, you might use something like:
# DATABASE_URL=postgresql+asyncpg://username:password@db-host:5432/database_name

# Redis Configuration  
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-change-in-production

# Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Theme Park Planner API

# Database Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Connection Settings
REDIS_MAX_CONNECTIONS=10

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30