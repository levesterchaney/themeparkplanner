# Database Configuration - Individual Components (Recommended)
# These will be automatically combined into a connection URL
DB_DRIVER=postgresql+asyncpg
DB_USER=tppuser
DB_PASSWORD=tppdev123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=themeparkplanner

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-change-in-production

# Environment
ENVIRONMENT=development
DEBUG=true

# Database Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Connection Settings
REDIS_MAX_CONNECTIONS=10

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Session Management
SESSION_TIMEOUT_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1

# Frontend Configuration
FRONTEND_HOST=http://localhost
FRONTEND_PORT=3000

# Email Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Theme Park Planner
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
USE_CREDENTIALS=true
VALIDATE_CERTS=true
